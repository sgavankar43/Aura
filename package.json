{
  "name": "aura",
  "version": "1.0.0",
  "private": true,
  "description": "Aura — AI-Agent driven distributed systems platform",
  "workspaces": [
    "Client",
    "Server",
    "SDK"
  ],
  "scripts": {
    "dev:server": "npm run dev --workspace=Server",
    "dev:client": "npm run dev --workspace=Client",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces",
    "test:coverage": "npm run test:coverage --workspaces",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\"",
    "check:architecture": "bash scripts/check-architecture.sh",
    "audit:security": "bash scripts/security-audit.sh",
    "tdd:check": "bash scripts/tdd-check.sh",
    "validate:all": "npm run lint && npm run check:architecture && npm run audit:security && npm run test:coverage",
    "prepare": "husky"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "concurrently": "^8.2.0",
    "dependency-cruiser": "^16.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.0",
    "husky": "^9.1.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "graphifyy": "^0.4.23"
  }
}
