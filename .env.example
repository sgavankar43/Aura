# =============================================================================
# Aura Environment Configuration
# Copy this file to .env and fill in the values
# NEVER commit the .env file — use .env.example as the template
# =============================================================================

# Server
NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# CORS
CORS_ORIGIN=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=debug

# Database (configure when database is added)
# DATABASE_URL=postgresql://user:password@localhost:5432/aura

# Redis (configure when caching is added)
# REDIS_URL=redis://localhost:6379
