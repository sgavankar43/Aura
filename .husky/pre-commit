#!/usr/bin/env sh

# Pre-commit hook — enforces quality gates before every commit
# Runs: lint-staged (ESLint + Prettier), architecture check, secrets scan

echo "🔍 Running pre-commit checks..."

# 1. Lint-staged (ESLint + Prettier on staged files)
npx lint-staged

# 2. Quick architecture boundary check
echo "🏗️  Checking architecture boundaries..."
VIOLATIONS=$(grep -rn "from.*repositories" Server/src/routes/ 2>/dev/null || true)
VIOLATIONS2=$(grep -rn "from.*repositories" Server/src/controllers/ 2>/dev/null || true)
VIOLATIONS3=$(grep -rn "from.*services" Server/src/routes/ 2>/dev/null || true)

if [ -n "$VIOLATIONS" ] || [ -n "$VIOLATIONS2" ] || [ -n "$VIOLATIONS3" ]; then
  echo "❌ Architecture boundary violation detected!"
  echo "$VIOLATIONS"
  echo "$VIOLATIONS2"
  echo "$VIOLATIONS3"
  exit 1
fi

# 3. Quick secrets check on staged files
echo "🔑 Scanning for secrets..."
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx|js|jsx)$' || true)
if [ -n "$STAGED_FILES" ]; then
  for file in $STAGED_FILES; do
    if grep -qE "(password|api_key|apiKey|secret)\s*[:=]\s*['\"][^'\"]{8,}['\"]" "$file" 2>/dev/null; then
      if ! echo "$file" | grep -qE "(\.test\.|__tests__|\.example)"; then
        echo "⚠️  Potential hardcoded secret in: $file"
        echo "   Use environment variables instead."
        exit 1
      fi
    fi
  done
fi

echo "✅ Pre-commit checks passed!"
